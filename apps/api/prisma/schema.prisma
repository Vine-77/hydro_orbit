generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  FARMER
  ADMIN
}

enum SensorType {
  MOISTURE
  PH
  WATER_LEVEL
}

enum SensorStatus {
  ONLINE
  OFFLINE
  LOW_BATTERY
}

enum IrrigationTrigger {
  AUTO
  MANUAL
  SCHEDULED
}

enum IrrigationStatus {
  ACTIVE
  COMPLETED
  FAILED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model User {
  id           String    @id @default(uuid())
  phone        String    @unique
  passwordHash String
  name         String
  role         UserRole  @default(FARMER)
  farms        Farm[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Farm {
  id        String   @id @default(uuid())
  name      String
  location  String
  area      Float
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  zones     Zone[]
  sensors   Sensor[]
  alerts    Alert[]
  createdAt DateTime @default(now())
}

model Zone {
  id                String              @id @default(uuid())
  name              String
  farmId            String
  farm              Farm                @relation(fields: [farmId], references: [id])
  cropType          String
  moistureThreshold Float
  sensors           Sensor[]
  irrigationEvents IrrigationEvent[]
  schedules         IrrigationSchedule[]
}

model Sensor {
  id           String         @id
  type         SensorType
  zoneId       String?
  zone         Zone?          @relation(fields: [zoneId], references: [id])
  farmId       String
  farm         Farm           @relation(fields: [farmId], references: [id])
  lastReading  Float?
  battery      Float?
  status       SensorStatus   @default(ONLINE)
  readings     SensorReading[]
  alerts       Alert[]
}

model SensorReading {
  id         String   @id @default(uuid())
  sensorId   String
  sensor     Sensor   @relation(fields: [sensorId], references: [id])
  value      Float
  timestamp  DateTime @default(now())
}

model IrrigationEvent {
  id        String            @id @default(uuid())
  zoneId    String
  zone      Zone              @relation(fields: [zoneId], references: [id])
  startTime DateTime          @default(now())
  endTime   DateTime?
  duration  Int?
  volume    Float?
  trigger   IrrigationTrigger
  status    IrrigationStatus @default(ACTIVE)
}

model Alert {
  id           String        @id @default(uuid())
  farmId       String
  farm         Farm          @relation(fields: [farmId], references: [id])
  zoneId       String?
  sensorId     String?
  sensor       Sensor?       @relation(fields: [sensorId], references: [id])
  severity     AlertSeverity
  message      String
  acknowledged Boolean        @default(false)
  createdAt    DateTime       @default(now())
}

model IrrigationSchedule {
  id       String  @id @default(uuid())
  zoneId   String
  zone     Zone    @relation(fields: [zoneId], references: [id])
  days     String[]
  time     String
  duration Int
  enabled  Boolean @default(true)
}
